CI_ENVIRONMENT = development

app.baseURL = 'http://localhost:8080/'
app.indexPage = ''
app.defaultLocale = 'es'
# In production, set to true to force HTTPS on all requests
app.forceGlobalSecureRequests = false

database.default.hostname = localhost
database.default.database = codex
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

logger.threshold = 4

# ── Security (Phase 0+) ──────────────────────────────────
# JWT secret for API authentication (Phase 1, min 32 chars)
# jwt.secret = 'CHANGE-ME-TO-A-RANDOM-64-CHAR-STRING'

# Encryption key for sensitive data (openssl rand -hex 32)
# encryption.key = hex2bin:CHANGE_ME

# ── Codex Assist AI (Phase 6) ────────────────────────────
# Provider: 'ollama' (local) or 'openai' (cloud)
# codex.assist.provider = ollama
# codex.assist.model = llama3.2
# codex.assist.url = http://localhost:11434
# codex.assist.api_key = sk-your-openai-key-here

